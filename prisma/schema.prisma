// Discipleship Dashboard — Prisma Schema
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}
datasource db {
  provider = "postgresql"
}
// ─── ENUMS ──────────────────────────────────────────────
enum Role {
  ADMIN
  SCHEDULE_LEADER
  SECRETARY
  FACILITATOR
}
enum ScheduleDay {
  WEDNESDAY
  SUNDAY
}
enum AttendanceStatus {
  PRESENT
  ABSENT
  PREVIEWED
  RECOVERED
}
enum AbsentReason {
  SICK
  WORK
  PERSONAL
  TRAVEL
  OTHER
}
enum EventCategory {
  BIRTHDAY
  CLASS
  COURSE_DATE
  SNACK
  DYNAMICS
  OTHER
}
enum StudentStatus {
  ACTIVE
  QUIT
}
// ─── AUTH & USERS ───────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String    // hashed
  name          String
  role          Role
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  // Role-specific relations
  facilitator   Facilitator?
  scheduleLeaders ScheduleLeader[]
  secretaries     Secretary[]
  calendarEvents  CalendarEvent[]
  studentNotes  StudentNote[]
}
// ─── CORE MODELS ────────────────────────────────────────
model Course {
  id          String     @id @default(cuid())
  name        String     // e.g. "Course 1 - 2025"
  year        Int
  semester    Int        // 1 or 2 (two courses per year)
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  schedules   Schedule[]
}
model Schedule {
  id          String       @id @default(cuid())
  day         ScheduleDay
  time        String       // e.g. "09:00", "13:00"
  label       String       // e.g. "Sunday 9:00 AM"
  courseId     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  classes     Class[]
  tables      FacilitatorTable[]
  leaders     ScheduleLeader[]
  secretaries Secretary[]
  attendances Attendance[]
  calendarEvents CalendarEvent[]
  @@unique([courseId, day, time])
}
model Class {
  id          String     @id @default(cuid())
  name        String     // e.g. "Session 1: Introduction"
  date        DateTime
  topic       String?
  scheduleId  String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  schedule    Schedule   @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  attendance  Attendance[]
}
// ─── PEOPLE ─────────────────────────────────────────────
model Facilitator {
  id          String     @id @default(cuid())
  name        String
  birthday    DateTime?
  userId      String?    @unique
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User?      @relation(fields: [userId], references: [id])
  tables      FacilitatorTable[]
}
model ScheduleLeader {
  id          String     @id @default(cuid())
  userId      String
  scheduleId  String
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id])
  schedule    Schedule   @relation(fields: [scheduleId], references: [id])
}
model Secretary {
  id          String     @id @default(cuid())
  userId      String
  scheduleId  String
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id])
  schedule    Schedule   @relation(fields: [scheduleId], references: [id])
}
model FacilitatorTable {
  id             String     @id @default(cuid())
  name           String     // e.g. "Table 1"
  facilitatorId  String
  scheduleId     String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  facilitator    Facilitator @relation(fields: [facilitatorId], references: [id])
  schedule       Schedule    @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  students       Student[]
}
model Student {
  id            String     @id @default(cuid())
  firstName     String
  lastName      String
  birthdate     DateTime?
  phone         String?
  address       String?
  profileNotes  Json?      // Flexible field for church-related questions
  tableId       String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  table         FacilitatorTable? @relation(fields: [tableId], references: [id])
  attendance    Attendance[]
  status        StudentStatus @default(ACTIVE)
  quitDate      DateTime?
  quitReason    String?
  notes       StudentNote[]
}
model StudentNote {
  id        String   @id @default(cuid())
  content   String
  studentId String
  authorId  String
  createdAt DateTime @default(now())

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
}
// ─── ATTENDANCE ─────────────────────────────────────────
model Attendance {
  id                String           @id @default(cuid())
  status            AttendanceStatus @default(PRESENT)
  absentReason      AbsentReason?    // Only when status = ABSENT
  absentNote        String?          // Optional text note for ABSENT
  altScheduleId     String?          // Which schedule they attended (PREVIEWED/RECOVERED)
  studentId         String
  classId           String
  markedById        String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  student           Student          @relation(fields: [studentId], references: [id])
  class             Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  altSchedule       Schedule?        @relation(fields: [altScheduleId], references: [id])
  @@unique([studentId, classId])
}
// ── Cam Scanner ───────────────────────────────────────
model ProfileQuestion {
  id        String   @id @default(cuid())
  question  String
  type      String   @default("text")  // "text", "select", "boolean"
  options   Json?                       // For select type: ["Sí", "No"]
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
// ─── CALENDAR ───────────────────────────────────────────
model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  date        DateTime
  description String?
  createdById String?
  scheduleId  String?   // null = global event (visible to admin)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  schedule    Schedule? @relation(fields: [scheduleId], references: [id])
  category    EventCategory @default(OTHER)
}
// ─── APP SETTINGS ───────────────────────────────────────
model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}